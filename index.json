{"version":3,"kind":"Article","sha256":"23d86fbc45c3851536eae13fb784cd2b4eae85b9e04d745451823fe45f378015","slug":"index","location":"/intro.md","dependencies":[],"frontmatter":{"title":"Threats to Commitment","content_includes_title":false,"authors":[{"nameParsed":{"literal":"Karna Basu","given":"Karna","family":"Basu"},"name":"Karna Basu","id":"contributors-myst-generated-uid-0"},{"nameParsed":{"literal":"Jonathan Conning","given":"Jonathan","family":"Conning"},"name":"Jonathan Conning","id":"contributors-myst-generated-uid-1"}],"github":"https://github.com/jhconning/commitments","source_url":"https://github.com/jhconning/commitments/blob/main/intro.md","edit_url":"https://github.com/jhconning/commitments/edit/main/intro.md","thumbnail":"/commitments/build/logo-9ac9a77fdd96c9a11e7f66d4d863d995.png","exports":[{"format":"md","filename":"intro.md","url":"/commitments/build/intro-7963adf6adcc51cb43825f08360483ee.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Appendix and replication code for:","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"IVgVShdiYl"}],"key":"KmpZdbRiUQ"}],"key":"nJw2MW5fM1"},{"type":"blockquote","position":{"start":{"line":7,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Basu, Karna and Jonathan Conning (2021) ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"vanS9QIRpI"},{"type":"link","url":"https://drive.google.com/open?id=1a2CKZTwuNIGw8oWCxOY0_AuljjWkGg6Z&authuser=jonathan.conning%40gmail.com&usp=drive_fs","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Threats to Commitment: Contracting with Present-Biased Consumers under Renegotiation Concerns","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"YrRi4fOoKu"}],"urlSource":"https://drive.google.com/open?id=1a2CKZTwuNIGw8oWCxOY0_AuljjWkGg6Z&authuser=jonathan.conning%40gmail.com&usp=drive_fs","key":"yCx17BMLnH"},{"type":"text","value":", manuscript.\n","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"JyCmKP6I7b"},{"type":"text","value":"\n","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"ljYzHrn1vu"},{"type":"strong","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Abstract:","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"MW7RwFTx4W"}],"key":"TKIBsVmAb1"},{"type":"text","value":" Hyperbolic discounters value consumption-smoothing commitment contracts, but may fear that these could be renegotiated by future selves and banks. This creates a consumer protection problem even for sophisticated and informed consumers. This paper studies how the threat of renegotiation affects equilibrium commitment contracts and bank governance forms. We find that familiar behaviors such as ‘over’-borrowing or ‘under’-saving emerge, but here as strategic partial concessions to future selves to avoid even costlier renegotiation behaviors later. We then show how it may be to banks’ advantage to offer additional consumer protection either via an appeal for government regulation or through costly private governance/ownership choices. By restricting their own ability to profit from opportunistic renegotiation, banks can expand gains to trade and captured profits. The framework establishes new behavioral micro-foundations for a theory of commercial non-profits and helps explain historical patterns of contracting and ownership forms in consumer banking and microfinance, and how these co-evolved with market structure.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"DZdp251JfI"}],"key":"SWMME1zRxV"}],"key":"SSiIhCBK6D"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"Follow the links in the navigation bar at left to interactive notebooks that replicate the figures and allow changes to parameter values. All code is in ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"KDpC6S3VfL"},{"type":"link","url":"https://github.com/jhconning/commitments/blob/main/notebooks/Contract.py","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"Contract.py","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"GvOZ7IqOO5"}],"urlSource":"https://github.com/jhconning/commitments/blob/main/notebooks/Contract.py","data":{"kind":"file","org":"jhconning","repo":"commitments","reference":"main","file":"notebooks/Contract.py","raw":"https://raw.githubusercontent.com/jhconning/commitments/main/notebooks/Contract.py"},"internal":false,"protocol":"github","key":"AtqJO1usXd"},{"type":"text","value":" with additional detail and usage demonstrated in the notebooks.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"pfCWqGP62D"}],"key":"Ca9VkbsTUy"},{"type":"image","url":"/commitments/build/logo-9ac9a77fdd96c9a11e7f66d4d863d995.png","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"EZFFJfAlg7","urlSource":"logo.png"}],"key":"hw32JP49G4"}],"key":"vpMGq3JBgX"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"next":{"title":"Figure 1 Replication","url":"/notebooks/figure1","group":"Code and Figures"}}},"domain":"http://localhost:3000"}